<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.fitmate.controller.SignupController"
      alignment="CENTER" spacing="0" style="-fx-background-color: #121212;">

    <!-- Navbar -->
    <HBox styleClass="navbar" alignment="CENTER_LEFT">
        <HBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
            <Label text="Fit" style="-fx-text-fill: #00C897; -fx-font-size: 28px; -fx-font-weight: 800; -fx-cursor: hand;"
                   onMouseClicked="#goToLanding"/>
            <Label text="Mate" style="-fx-text-fill: #E0E0E0; -fx-font-size: 28px; -fx-font-weight: 800; -fx-cursor: hand;"
                   onMouseClicked="#goToLanding"/>
        </HBox>
        <Button text="← Back" styleClass="btn-ghost" style="-fx-text-fill: #00C897;" onAction="#goToLanding"/>
    </HBox>

    <!-- Center Form -->
    <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
        <VBox styleClass="card" spacing="20" maxWidth="420" alignment="CENTER">
            <padding><Insets top="30" bottom="30" left="30" right="30"/></padding>

            <Label text="Create Account" styleClass="label-heading" style="-fx-text-fill: #00C897;"/>

            <!-- Error Label -->
            <Label fx:id="errorLabel" styleClass="label-error" visible="false" managed="false" wrapText="true"/>

            <!-- Email -->
            <VBox spacing="5">
                <Label text="Email Address" styleClass="label-secondary" style="-fx-font-size: 13px;"/>
                <TextField fx:id="emailField" promptText="your@email.com"/>
            </VBox>

            <!-- Password -->
            <VBox spacing="5">
                <Label text="Password" styleClass="label-secondary" style="-fx-font-size: 13px;"/>
                <PasswordField fx:id="passwordField" promptText="Create a password"/>
            </VBox>

            <!-- Confirm Password -->
            <VBox spacing="5">
                <Label text="Confirm Password" styleClass="label-secondary" style="-fx-font-size: 13px;"/>
                <PasswordField fx:id="confirmField" promptText="Re-enter your password"/>
            </VBox>

            <!-- Signup Button -->
            <Button fx:id="signupButton" text="Sign Up" styleClass="btn-primary"
                    maxWidth="Infinity" onAction="#handleSignup"/>

            <!-- Login Link -->
            <HBox alignment="CENTER" spacing="5">
                <Label text="Already have an account?" styleClass="label-secondary"/>
                <Hyperlink text="Log in here." onAction="#goToLogin"/>
            </HBox>
        </VBox>
    </VBox>
</VBox>
